{
  "_description": "Baseline Configuration for Quest Analytics RAG Assistant - Phase 1 Evaluation",
  "_purpose": "This configuration file defines the baseline parameters for initial RAG system evaluation, establishing reference metrics for performance comparison and optimization.",
  "_features": [
    "OpenSearch cluster configuration for document indexing",
    "Hybrid retrieval parameters balancing BM25 and vector search",
    "Baseline embedding model settings for reproducible evaluation", 
    "LLM integration parameters with Ollama chat adapter",
    "Evaluation metrics and dataset configuration",
    "Performance measurement and logging settings"
  ],
  "_usage": "Used by baseline_evaluation.py and run_baseline_evaluation.py for establishing performance baselines before optimization",
  
  "system": {
    "name": "ai_rag_assistant",
    "version": "1.0.0",
    "environment": "baseline_evaluation"
  },
  
  "opensearch": {
    "host": "localhost",
    "port": 9200,
    "use_ssl": false,
    "verify_certs": false,
    "index_name": "documents",
    "timeout": 30,
    "max_retries": 3,
    "retry_on_timeout": true
  },
  
  "retrieval": {
    "top_k": 10,
    "search_type": "hybrid",
    "similarity_threshold": 0.0,
    "boost_exact_matches": true,
    "boost_factor": 1.2,
    "max_query_length": 512
  },
  
  "embedding": {
    "model": "sentence-transformers/all-mpnet-base-v2",
    "device": "auto",
    "batch_size": 32,
    "max_length": 384,
    "normalize": true
  },
  
  "reranker": {
    "enabled": true,
    "model": "sentence-transformers/ms-marco-MiniLM-L-2-v1",
    "device": "auto",
    "batch_size": 16,
    "top_k": 5,
    "score_threshold": 0.0
  },
  
  "llm": {
    "provider": "ollama",
    "base_url": "http://localhost:11434",
    "model": "llama3",
    "temperature": 0.1,
    "max_tokens": 512,
    "timeout": 60,
    "stream": false,
    "context_window": 2048
  },
  
  "generation": {
    "enabled": false,
    "max_context_length": 1500,
    "include_metadata": false,
    "citation_format": "brackets",
    "fallback_response": "I don't have enough information to answer this question accurately."
  },
  
  "evaluation": {
    "metrics": [
      "retrieval_accuracy",
      "response_time", 
      "top_k_recall",
      "semantic_similarity",
      "keyword_coverage"
    ],
    "quality_thresholds": {
      "min_top_1_score": 0.6,
      "max_response_time_ms": 2000,
      "min_keyword_coverage": 0.5
    }
  },
  
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file_enabled": true,
    "file_path": "logs/evaluation.log",
    "rotation_max_bytes": 10485760,
    "rotation_backup_count": 5
  },
  
  "performance": {
    "enable_caching": true,
    "cache_size": 1000,
    "enable_batching": true,
    "batch_size": 10,
    "parallel_workers": 4,
    "memory_limit_mb": 2048
  },
  
  "experimental": {
    "enable_query_expansion": false,
    "enable_semantic_filtering": false,
    "enable_result_clustering": false,
    "enable_confidence_scoring": false
  }
}