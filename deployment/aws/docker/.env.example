# Quest Analytics RAG Assistant - Environment Configuration Template
# Copy this file to .env and customize values for your deployment
# All settings have sensible defaults for development environments

# Ollama Model Configuration
OLLAMA_MODEL=gemma3:1b
OLLAMA_FALLBACK_MODEL=phi3:mini
OLLAMA_TIMEOUT=240

# Landing Page Configuration  
APP_URL=http://localhost:7860
ENABLE_ANALYTICS=false
ANALYTICS_PROVIDER=plausible
ANALYTICS_ID=

# OpenSearch Configuration
OPENSEARCH_TLS_VERIFY=false

# Development Settings
GRADIO_SHARE_LINK=false